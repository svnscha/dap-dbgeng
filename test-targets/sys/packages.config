<?xml version="1.0" encoding="utf-8"?>
<!--
  WDK delivered via NuGet. The build (cmake/FindWDKNuGet.cmake) consumes these from
  the per-user global cache (%USERPROFILE%\.nuget\packages) or a local .\packages
  dir. Restore with test-targets/sys/Restore-Wdk.ps1, or let Visual Studio restore them.

    Microsoft.Windows.WDK.x64  -> kernel headers (km), kernel libs, build tools
    Microsoft.Windows.SDK.CPP  -> shared/um/ucrt headers (ntdef.h etc.)

  Both resolve to SDK include version 10.0.26100.0 (Windows 11 24H2 line).
-->
<packages>
  <package id="Microsoft.Windows.WDK.x64" version="10.0.26100.6584" targetFramework="native" />
  <package id="Microsoft.Windows.SDK.CPP" version="10.0.26100.7705" targetFramework="native" />
</packages>
